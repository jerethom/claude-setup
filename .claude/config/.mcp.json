{
  "mcpServers": {
    "postgres": {
      "type": "stdio",
      "command": "mise",
      "args": [
        "exec",
        "bun@1.3.5",
        "--",
        "bunx",
        "@bytebase/dbhub",
        "--dsn",
        "postgresql://postgres:postgres@localhost:5432/postgres"
      ]
    },
    "demongrep": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "~/.local/share/claude-setup/demongrep/target/release/demongrep mcp ."
      ]
    },
    "CodeGraphContext": {
      "type": "stdio",
      "command": "mise",
      "args": [
        "exec",
        "python@3.14.2",
        "--",
        "cgc",
        "mcp",
        "start"
      ],
      "env": {
        "NEO4J_URI": "neo4j://localhost:7687",
        "NEO4J_USERNAME": "neo4j",
        "NEO4J_PASSWORD": "password",
        "DEFAULT_DATABASE": "neo4j"
      },
      "tools": {
        "alwaysAllow": [
          "add_code_to_graph",
          "add_package_to_graph",
          "check_job_status",
          "list_jobs",
          "find_code",
          "analyze_code_relationships",
          "watch_directory",
          "find_dead_code",
          "execute_cypher_query",
          "calculate_cyclomatic_complexity",
          "find_most_complex_functions",
          "list_indexed_repositories",
          "delete_repository",
          "list_watched_paths",
          "unwatch_directory",
          "visualize_graph_query"
        ],
        "disabled": false
      },
      "disabled": false,
      "alwaysAllow": []
    },
    "context7": {
      "type": "stdio",
      "command": "mise",
      "args": [
        "exec",
        "bun@1.3.5",
        "--",
        "bunx",
        "@upstash/context7-mcp"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "mise",
      "args": [
        "exec",
        "bun@1.3.5",
        "--",
        "bunx",
        "@playwright/mcp@latest"
      ]
    },
    "mobile-mcp": {
      "type": "stdio",
      "command": "mise",
      "args": [
        "exec",
        "bun@1.3.5",
        "--",
        "bunx",
        "@mobilenext/mobile-mcp@latest"
      ]
    }
  }
}